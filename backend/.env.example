NODE_ENV=production
PORT=3000
JWT_SECRET=change-this-to-a-long-random-secret
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-publishable-key
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require
STARTUP_READY_TIMEOUT_MS=15000
DATABASE_PATH=/var/data/pisowifi-admin.db
UPLOADS_DIR=/var/data/package-images
ACCOUNT_BACKUP_MONGODB_URI=
ACCOUNT_BACKUP_MONGODB_DB=cynetwork_pisowifi
ACCOUNT_BACKUP_MONGODB_COLLECTION=client_account_backups
ACCOUNT_BACKUP_MONGODB_SRV_FALLBACK=true
ACCOUNT_BACKUP_MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
AMAZON_LEO_SMS_ENABLED=true
AMAZON_LEO_SMS_PROVIDER=semaphore
SEMAPHORE_API_KEY=
SEMAPHORE_SENDER_NAME=CYNETWORK
EMAIL_VERIFICATION_ENABLED=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_ALLOW_UNAUTH=false
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=CYNETWORK PISOWIFI
EMAIL_CODE_TTL_MINUTES=10
EMAIL_CODE_RESEND_COOLDOWN_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5
