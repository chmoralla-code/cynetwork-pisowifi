NODE_ENV=production
PORT=3000
JWT_SECRET=change-this-to-a-long-random-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
DATABASE_PATH=./pisowifi-admin.db
UPLOADS_DIR=./public/package-images
ACCOUNT_BACKUP_MONGODB_URI=
ACCOUNT_BACKUP_MONGODB_DB=cynetwork_pisowifi
ACCOUNT_BACKUP_MONGODB_COLLECTION=client_account_backups
ACCOUNT_BACKUP_MONGODB_SRV_FALLBACK=true
ACCOUNT_BACKUP_MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
